// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`statsCommand --retroactive integration > prints retroactive stats correctly using real fixtures 1`] = `
"Parecode — last 10000d (retroactive scan)
─────────────────────
Sessions:                         2
Tool calls:                       5
Calls batched (est):              0
Tokens saved (lower-bound est):   280

* Lower-bound assumes a realistic baseline (model would do targeted reads,
  not full-file reads). Pass --upper-bound for the naive "Read every matched
  file in full" counterfactual (~3× larger).
* Retroactive savings are estimated, not measured.
"
`;
