{
  "name": "parecode",
  "version": "0.5.0",
  "description": "MCP server for token-aware code search and safe, atomic multi-file edits — built to cut Claude Code token usage on large codebases without giving up correctness.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "claude-code",
    "ast",
    "tree-sitter",
    "ripgrep",
    "code-search",
    "code-edit",
    "developer-tools"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BasilSkyWalk/parecode.git"
  },
  "bugs": {
    "url": "https://github.com/BasilSkyWalk/parecode/issues"
  },
  "homepage": "https://github.com/BasilSkyWalk/parecode#readme",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "test": "vitest run"
  },
  "bin": {
    "parecode": "./dist/cli/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "plugins",
    ".claude-plugin",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@vscode/ripgrep": "^1.18.0",
    "env-paths": "^4.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/env-paths": "^1.0.2",
    "@types/node": "^25.9.1",
    "fast-check": "^4.8.0",
    "tmp-promise": "^3.0.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
